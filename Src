function AuroraLib:Notify(data)
	data = data or {}
	local title = data.Title or "Notification"
	local content = data.Content or "Content"
	local duration = data.Duration or 5
	local icon = data.Icon or ""

	local notif = Create("Frame", {
		Name = "Notification",
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		BackgroundColor3 = AuroraLib.Theme[AuroraLib.SelectedTheme].NotificationBG,
		Parent = NotificationHolder
	}, {
		Create("UICorner", {CornerRadius = UDim.new(0, 6)}),
		Create("UIStroke", {
			Color = AuroraLib.Theme[AuroraLib.SelectedTheme].NotificationStroke,
			Thickness = 1.2
		}),
		Create("UIPadding", {
			PaddingBottom = UDim.new(0, 12),
			PaddingLeft = UDim.new(0, 12),
			PaddingRight = UDim.new(0, 12),
			PaddingTop = UDim.new(0, 12)
		})
	})

	local titleLabel = Create("TextLabel", {
		Name = "Title",
		Text = title,
		Font = Enum.Font.GothamBold,
		TextSize = 14,
		TextColor3 = AuroraLib.Theme[AuroraLib.SelectedTheme].Text,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -30, 0, 20),
		Position = UDim2.new(0, 30, 0, 0),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = notif
	})

	if icon ~= "" then
		local iconImg = Create("ImageLabel", {
			Name = "Icon",
			Image = icon,
			Size = UDim2.new(0, 20, 0, 20),
			ImageColor3 = AuroraLib.Theme[AuroraLib.SelectedTheme].Text,
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 0, 0, 0),
			Parent = notif
		})
		titleLabel.Position = UDim2.new(0, 30, 0, 0)
	end

	local contentLabel = Create("TextLabel", {
		Name = "Content",
		Text = content,
		Font = Enum.Font.GothamSemibold,
		TextSize = 13,
		TextColor3 = AuroraLib.Theme[AuroraLib.SelectedTheme].TextDark,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 0),
		Position = UDim2.new(0, 0, 0, 25),
		TextXAlignment = Enum.TextXAlignment.Left,
		TextWrapped = true,
		AutomaticSize = Enum.AutomaticSize.Y,
		Parent = notif
	})

	notif.Size = UDim2.new(1, 0, 0, contentLabel.AbsoluteSize.Y + 40)
	notif.Position = UDim2.new(1, 0, 0, 0)
	TweenService:Create(notif, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {Position = UDim2.new(0, 0, 0, 0)}):Play()

	task.delay(duration - 0.88, function()
		TweenService:Create(notif, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {BackgroundTransparency = 0.5, Position = UDim2.new(1, 20, 0, 0)}):Play()
		TweenService:Create(titleLabel, TweenInfo.new(0.4), {TextTransparency = 0.5}):Play()
		TweenService:Create(contentLabel, TweenInfo.new(0.4), {TextTransparency = 0.6}):Play()
		if icon ~= "" then
			TweenService:Create(notif.Icon, TweenInfo.new(0.4), {ImageTransparency = 1}):Play()
		end
		task.delay(0.6, function()
			notif:Destroy()
		end)
	end)
end

