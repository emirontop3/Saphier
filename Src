-- Utility Functions
local function Create(className, properties, children)
	local obj = Instance.new(className)
	for prop, value in pairs(properties or {}) do
		obj[prop] = value
	end
	for _, child in ipairs(children or {}) do
		child.Parent = obj
	end
	return obj
end

local function CreateElement(elementName, elementFunc)
	AuroraLib[elementName] = function(...)
		return elementFunc(...)
	end
end

local function Round(num, factor)
	return math.floor(num/factor + 0.5) * factor
end

local function AddThemeObject(obj, category)
	if not AuroraLib.ThemeObjects[category] then
		AuroraLib.ThemeObjects[category] = {}
	end
	table.insert(AuroraLib.ThemeObjects[category], obj)
	local theme = AuroraLib.Theme[AuroraLib.SelectedTheme]
	if theme and theme[category] then
		if obj:IsA("Frame") or obj:IsA("TextButton") then
			obj.BackgroundColor3 = theme[category]
		elseif obj:IsA("UIStroke") then
			obj.Color = theme[category]
		elseif obj:IsA("TextLabel") or obj:IsA("TextBox") then
			obj.TextColor3 = theme[category]
		elseif obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
			obj.ImageColor3 = theme[category]
		elseif obj:IsA("ScrollingFrame") then
			obj.ScrollBarImageColor3 = theme[category]
		end
	end
	return obj
end

local function UpdateTheme()
	for category, objects in pairs(AuroraLib.ThemeObjects) do
		local color = AuroraLib.Theme[AuroraLib.SelectedTheme][category]
		if color then
			for _, obj in ipairs(objects) do
				if obj:IsA("Frame") or obj:IsA("TextButton") then
					obj.BackgroundColor3 = color
				elseif obj:IsA("UIStroke") then
					obj.Color = color
				elseif obj:IsA("TextLabel") or obj:IsA("TextBox") then
					obj.TextColor3 = color
				elseif obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
					obj.ImageColor3 = color
				elseif obj:IsA("ScrollingFrame") then
					obj.ScrollBarImageColor3 = color
				end
			end
		end
	end
end

local function PackColor(color)
	return {R = color.R * 255, G = color.G * 255, B = color.B * 255}
end

local function UnpackColor(packed)
	return Color3.fromRGB(packed.R, packed.G, packed.B)
end

local function SaveCfg(name, data)
	if not writefile then return end
	local folder = AuroraLib.Folder .. "/Configurations"
	if not isfolder(folder) then makefolder(folder) end
	writefile(folder .. "/" .. name .. ".json", HttpService:JSONEncode(data))
end

local function LoadCfg(name)
	if not readfile then return nil end
	local folder = AuroraLib.Folder .. "/Configurations"
	local path = folder .. "/" .. name .. ".json"
	if not isfile(path) then return nil end
	local success, content = pcall(readfile, path)
	if success and content then
		local ok, decoded = pcall(HttpService.JSONDecode, HttpService, content)
		if ok then return decoded end
	end
	return nil
end

