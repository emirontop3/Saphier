-- Button
function Elements:AddButton(data)
    local frame = CreateElementFrame(self.Container, 38)
    local label = Create("TextLabel", {
        Parent = frame,
        Size = UDim2.new(1, -16, 1, 0),
        Position = UDim2.new(0, 16, 0, 0),
        Text = data.Name,
        Font = Enum.Font.GothamBold,
        TextColor3 = NovaUI.Theme.Text,
        BackgroundTransparency = 1,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 14,
    })
    local hover = false
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            Tween(frame, {BackgroundColor3 = NovaUI.Theme.Accent}, 0.1)
        end
    end)
    frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if hover then
                Tween(frame, {BackgroundColor3 = NovaUI.Theme.ElementHover}, 0.2)
            else
                Tween(frame, {BackgroundColor3 = NovaUI.Theme.Element}, 0.2)
            end
            pcall(data.Callback)
        end
    end)
    frame.MouseEnter:Connect(function()
        hover = true
        Tween(frame, {BackgroundColor3 = NovaUI.Theme.ElementHover}, 0.2)
    end)
    frame.MouseLeave:Connect(function()
        hover = false
        Tween(frame, {BackgroundColor3 = NovaUI.Theme.Element}, 0.2)
    end)
end

-- Toggle
function Elements:AddToggle(data)
    local toggle = {
        Save = data.Save or false,
        Type = "Toggle",
        Value = data.Default or false,
        Set = nil,
        Get = function(self) return self.Value end,
    }

    local frame = CreateElementFrame(self.Container, 38)
    local label = Create("TextLabel", {
        Parent = frame,
        Size = UDim2.new(1, -56, 1, 0),
        Position = UDim2.new(0, 16, 0, 0),
        Text = data.Name,
        Font = Enum.Font.GothamBold,
        TextColor3 = NovaUI.Theme.Text,
        BackgroundTransparency = 1,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 14,
    })

    local switch = Create("Frame", {
        Parent = frame,
        Size = UDim2.new(0, 36, 0, 20),
        Position = UDim2.new(1, -48, 0.5, -10),
        BackgroundColor3 = NovaUI.Theme.ToggleOff,
        Name = "Switch",
    }, {
        Create("UICorner", { CornerRadius = UDim.new(1, 0) }),
        Create("Frame", {
            Size = UDim2.new(0, 14, 0, 14),
            Position = UDim2.new(0, 4, 0.5, -7),
            BackgroundColor3 = Color3.new(1,1,1),
            Name = "Indicator",
        }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }) }),
    })

    local function updateState(state)
        toggle.Value = state
        Tween(switch, {BackgroundColor3 = state and NovaUI.Theme.ToggleOn or NovaUI.Theme.ToggleOff}, 0.2)
        Tween(switch.Indicator, {Position = state and UDim2.new(1, -18, 0.5, 0) or UDim2.new(0, 4, 0.5, 0)}, 0.2)
        if data.Callback then pcall(data.Callback, state) end
    end
    toggle.Set = updateState

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            updateState(not toggle.Value)
        end
    end)

    updateState(toggle.Value)
    if data.Flag then NovaUI.Flags[data.Flag] = toggle end
    return toggle
end

-- Slider
function Elements:AddSlider(data)
    local slider = {
        Save = data.Save or false,
        Type = "Slider",
        Value = data.Default or data.Min,
        Set = nil,
        Get = function(self) return self.Value end,
    }

    local frame = CreateElementFrame(self.Container, 52)
    local label = Create("TextLabel", {
        Parent = frame,
        Size = UDim2.new(1, -16, 0, 18),
        Position = UDim2.new(0, 16, 0, 5),
        Text = data.Name,
        Font = Enum.Font.GothamBold,
        TextColor3 = NovaUI.Theme.Text,
        BackgroundTransparency = 1,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 14,
    })

    local bar = Create("Frame", {
        Parent = frame,
        Size = UDim2.new(1, -32, 0, 22),
        Position = UDim2.new(0, 16, 0, 26),
        BackgroundColor3 = NovaUI.Theme.ElementHover,
        Name = "Bar",
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 4) }),
        Create("Frame", {
            Size = UDim2.new(0, 0, 1, 0),
            BackgroundColor3 = NovaUI.Theme.Slider,
            Name = "Fill",
        }, { Create("UICorner", { CornerRadius = UDim.new(0, 4) }) }),
        Create("TextLabel", {
            Size = UDim2.new(0, 50, 1, 0),
            Position = UDim2.new(1, 6, 0, 0),
            Text = "",
            Font = Enum.Font.GothamBold,
            TextColor3 = NovaUI.Theme.SubText,
            BackgroundTransparency = 1,
            TextXAlignment = Enum.TextXAlignment.Left,
            Name = "ValueLabel",
        }),
    })

    local function updateSlider(value)
        value = math.clamp(tonumber(value) or data.Min, data.Min, data.Max)
        slider.Value = value
        local factor = (value - data.Min) / (data.Max - data.Min)
        bar.Fill.Size = UDim2.new(factor, 0, 1, 0)
        bar.ValueLabel.Text = tostring(value) .. (data.Suffix or "")
        if data.Callback then pcall(data.Callback, value) end
    end
    slider.Set = updateSlider

    local dragging = false
    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
        end
    end)
    bar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local perc = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
            local val = data.Min + (data.Max - data.Min) * perc
            updateSlider(math.floor(val / data.Increment + 0.5) * data.Increment)
        end
    end)

    updateSlider(slider.Value)
    if data.Flag then NovaUI.Flags[data.Flag] = slider end
    return slider
end

-- Dropdown
function Elements:AddDropdown(data)
    local options = data.Options or {}
    local current = data.Default and table.find(options, data.Default) and data.Default or "Select..."
    local dropdown = {
        Save = data.Save or false,
        Type = "Dropdown",
        Value = current,
        Set = nil,
        Get = function(self) return self.Value end,
    }

    local frame = CreateElementFrame(self.Container, 38)
    local header = Create("Frame", {
        Parent = frame,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
    }, {
        Create("TextLabel", {
            Size = UDim2.new(1, -36, 1, 0),
            Position = UDim2.new(0, 16, 0, 0),
            Text = current,
            Font = Enum.Font.GothamBold,
            TextColor3 = NovaUI.Theme.Text,
            BackgroundTransparency = 1,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextSize = 14,
            Name = "SelectedText",
        }),
        Create("ImageButton", {
            Size = UDim2.new(0, 20, 0, 20),
            Position = UDim2.new(1, -30, 0.5, -10),
            Image = "rbxassetid://7072706796", -- down arrow
            BackgroundTransparency = 1,
            Name = "Arrow",
        }),
    })

    local list = Create("Frame", {
        Parent = frame,
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = NovaUI.Theme.Dropdown,
        ClipsDescendants = true,
        Visible = false,
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
        Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 2) }),
        Create("UIPadding", { PaddingTop = UDim.new(0, 2), PaddingBottom = UDim.new(0, 2) }),
    })

    local open = false
    header.Arrow.MouseButton1Click:Connect(function()
        open = not open
        if open then
            list.Size = UDim2.new(1, 0, 0, #options * 28 + 4)
            list.Visible = true
            Tween(header.Arrow, {Rotation = 180}, 0.2)
        else
            list.Visible = false
            Tween(header.Arrow, {Rotation = 0}, 0.2)
            Tween(frame, {Size = UDim2.new(1, 0, 0, 38)}, 0.2)
        end
    end)

    for _, opt in ipairs(options) do
        local optBtn = Create("TextButton", {
            Parent = list,
            Text = opt,
            Font = Enum.Font.Gotham,
            TextColor3 = NovaUI.Theme.Text,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -8, 0, 26),
            Position = UDim2.new(0, 4, 0, 0),
        }, { Create("UICorner", { CornerRadius = UDim.new(0, 4) }) })
        if opt == current then optBtn.BackgroundTransparency = 0.7 end
        optBtn.MouseButton1Click:Connect(function()
            current = opt
            dropdown.Value = opt
            header.SelectedText.Text = opt
            open = false
            list.Visible = false
            Tween(header.Arrow, {Rotation = 0}, 0.2)
            Tween(frame, {Size = UDim2.new(1, 0, 0, 38)}, 0.2)
            -- update background colors
            for _, btn in ipairs(list:GetChildren()) do
                if btn:IsA("TextButton") then
                    Tween(btn, {BackgroundTransparency = btn.Text == opt and 0.7 or 1}, 0.2)
                end
            end
            if data.Callback then pcall(data.Callback, opt) end
        end)
    end

    dropdown.Set = function(val)
        if table.find(options, val) then
            current = val
            dropdown.Value = val
            header.SelectedText.Text = val
            for _, btn in ipairs(list:GetChildren()) do
                if btn:IsA("TextButton") then
                    Tween(btn, {BackgroundTransparency = btn.Text == val and 0.7 or 1}, 0.2)
                end
            end
            if data.Callback then pcall(data.Callback, val) end
        end
    end

    if data.Flag then NovaUI.Flags[data.Flag] = dropdown end
    return dropdown
end

-- Keybind
function Elements:AddKeybind(data)
    local bind = data.Default or Enum.KeyCode.Unknown
    local keybind = {
        Save = data.Save or false,
        Type = "Keybind",
        Value = bind,
        Set = nil,
        Get = function(self) return self.Value end,
    }

    local frame = CreateElementFrame(self.Container, 38)
    local label = Create("TextLabel", {
        Parent = frame,
        Size = UDim2.new(1, -90, 1, 0),
        Position = UDim2.new(0, 16, 0, 0),
        Text = data.Name,
        Font = Enum.Font.GothamBold,
        TextColor3 = NovaUI.Theme.Text,
        BackgroundTransparency = 1,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextSize = 14,
    })

    local bindBtn = Create("TextButton", {
        Parent = frame,
        Size = UDim2.new(0, 70, 0, 26),
        Position = UDim2.new(1, -80, 0.5, -13),
        Text = bind.Name,
        Font = Enum.Font.GothamBold,
        TextColor3 = NovaUI.Theme.Text,
        BackgroundColor3 = NovaUI.Theme.Input,
        Name = "BindButton",
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 4) }),
        Create("UIStroke", { Color = NovaUI.Theme.ElementBorder }),
    })

    local binding = false
    bindBtn.MouseButton1Click:Connect(function()
        binding = true
        bindBtn.Text = "..."
    end)

    UserInputService.InputBegan:Connect(function(input)
        if binding then
            if input.KeyCode ~= Enum.KeyCode.Unknown then
                bind = input.KeyCode
                keybind.Value = bind
                bindBtn.Text = bind.Name
                binding = false
                if data.Callback then pcall(data.Callback, bind) end
            end
        elseif not binding and input.KeyCode == bind and not UserInputService:GetFocusedTextBox() then
            if data.Callback then pcall(data.Callback) end
        end
    end)

    keybind.Set = function(key)
        if typeof(key) == "EnumItem" then key = key end
        if typeof(key) == "string" then key = Enum.KeyCode[key] or bind end
        bind = key
        keybind.Value = bind
        bindBtn.Text = bind.Name
        if data.Callback then pcall(data.Callback, bind) end
    end

    if data.Flag then NovaUI.Flags[data.Flag] = keybind end
    return keybind
end

