--========== CONFIG SYSTEM ==========
AuroraLib.Flags = {}
AuroraLib.Folder = nil
AuroraLib.SaveCfg = false

function AuroraLib:LoadConfig()
    if not AuroraLib.SaveCfg or not isfolder or not isfile or not readfile then return end
    local path = AuroraLib.Folder .. "/" .. game.GameId .. ".json"
    if not isfile(path) then return end
    local success, data = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
    if not success then return end
    for flagName, flagVal in pairs(data) do
        if AuroraLib.Flags[flagName] then
            spawn(function()
                local flag = AuroraLib.Flags[flagName]
                local ok = pcall(function()
                    if flag.Type == "Colorpicker" then flag:Set(unpackColor(flagVal))
                    else flag:Set(flagVal) end
                end)
                if not ok then warn("Aurora – Failed to load flag "..flagName) end
            end)
        end
    end
    self:Notify({Title = "Config", Content = "Loaded saved configuration.", Duration = 4})
end
function AuroraLib:SaveConfig()
    if not AuroraLib.SaveCfg or not isfolder or not writefile then return end
    local data = {}
    for name, flag in pairs(AuroraLib.Flags) do
        if flag.Save then
            local ok, val = pcall(function()
                if flag.Type == "Colorpicker" then return packColor(flag.Value)
                else return flag.Value end
            end)
            if ok then data[name] = val end
        end
    end
    local path = AuroraLib.Folder .. "/" .. game.GameId .. ".json"
    pcall(function()
        if not isfolder(AuroraLib.Folder) then makefolder(AuroraLib.Folder) end
        writefile(path, HttpService:JSONEncode(data))
    end)
end

