    ["info"] = "http://www.roblox.com/asset/?id=6026568227",
    ["warning"] = "http://www.roblox.com/asset/?id=6031071053"
}
local function getIcon(name, source)
    source = source or "Material"
    if source == "Material" and MaterialIcons[name] then return MaterialIcons[name] end
    if source == "Lucide" and Icons[name] then
        local data = Icons[name]
        return {id = data[1], imageRectSize = Vector2.new(data[2][1], data[2][2]), imageRectOffset = Vector2.new(data[3][1], data[3][2])}
    end
    return "rbxassetid://" .. (name or "0")
end
local function applyIcon(obj, icon, source)
    if type(icon) == "table" then -- Lucide
        obj.Image = "rbxassetid://"..icon.id
        obj.ImageRectSize = icon.imageRectSize
        obj.ImageRectOffset = icon.imageRectOffset
        obj.ScaleType = Enum.ScaleType.Fit
    else
        obj.Image = getIcon(icon, source)
    end
end

