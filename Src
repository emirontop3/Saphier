-- ===================== UTILITY FUNCTIONS =====================
local function SafeDelay(t, f) delay(t, f) end

local function Create(className, props, children)
    local obj = Instance.new(className)
    for k, v in pairs(props or {}) do obj[k] = v end
    if children then
        for _, child in ipairs(children) do child.Parent = obj end
    end
    return obj
end

local function Tween(obj, goal, dur, style, dir)
    local tween = TweenService:Create(obj, TweenInfo.new(dur or 0.25, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out), goal)
    tween:Play()
    return tween
end

function NovaUI.AddConnection(sig, cb)
    local conn = sig:Connect(cb)
    table.insert(NovaUI.Connections, conn)
    return conn
end

local function Cleanup()
    for _, conn in ipairs(NovaUI.Connections) do
        conn:Disconnect()
    end
    NovaUI.Connections = {}
end

-- Mobile‑friendly dragging
local function MakeDraggable(frame, handle)
    local dragging, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    handle.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

-- Update scrollframe canvas size automatically
local function UpdateScroll(scroll)
    local layout = scroll:FindFirstChildWhichIsA("UIListLayout")
    if layout then
        local listener
        listener = layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
        end)
        scroll.Destroying:Connect(function() listener:Disconnect() end)
        -- initial update
        scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
    end
end

