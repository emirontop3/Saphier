        Font = Enum.Font.Gotham,
        TextColor3 = NovaUI.Theme.Text,
        BackgroundColor3 = NovaUI.Theme.Input,
        ClearTextOnFocus = false,
        Visible = false,
    })
    local gBox = Create("TextBox", {
        Parent = frame,
        Size = UDim2.new(0, 40, 0, 16),
        Position = UDim2.new(0, 260, 1, -28),
        Text = math.floor(color.G * 255),
        Font = Enum.Font.Gotham,
        TextColor3 = NovaUI.Theme.Text,
        BackgroundColor3 = NovaUI.Theme.Input,
        ClearTextOnFocus = false,
        Visible = false,
    })
    local bBox = Create("TextBox", {
        Parent = frame,
        Size = UDim2.new(0, 40, 0, 16),
        Position = UDim2.new(0, 320, 1, -28),
        Text = math.floor(color.B * 255),
        Font = Enum.Font.Gotham,
        TextColor3 = NovaUI.Theme.Text,
        BackgroundColor3 = NovaUI.Theme.Input,
        ClearTextOnFocus = false,
        Visible = false,
    })

    local function updateFromBoxes()
        local r = math.clamp(tonumber(rBox.Text) or 0, 0, 255)
        local g = math.clamp(tonumber(gBox.Text) or 0, 0, 255)
        local b = math.clamp(tonumber(bBox.Text) or 0, 0, 255)
        color = Color3.fromRGB(r, g, b)
        picker.Value = color
        preview.BackgroundColor3 = color
        if data.Callback then pcall(data.Callback, color) end
    end

    rBox.FocusLost:Connect(updateFromBoxes)
    gBox.FocusLost:Connect(updateFromBoxes)
    bBox.FocusLost:Connect(updateFromBoxes)

    -- Open/close button
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local anyVisible = rBox.Visible
            rBox.Visible = not anyVisible
            gBox.Visible = not anyVisible
            bBox.Visible = not anyVisible
            Tween(frame, {Size = UDim2.new(1, 0, 0, anyVisible and 38 or 60)}, 0.3)
        end
    end)

    picker.Set = function(clr)
        color = clr
        picker.Value = color
        preview.BackgroundColor3 = color
        rBox.Text = tostring(math.floor(color.R * 255))
        gBox.Text = tostring(math.floor(color.G * 255))
        bBox.Text = tostring(math.floor(color.B * 255))
        if data.Callback then pcall(data.Callback, color) end
    end

    if data.Flag then NovaUI.Flags[data.Flag] = picker end
    return picker
end

-- ===================== WINDOW CREATION =====================
function NovaUI:CreateWindow(config)
    local window = {}
    self.SaveCfg = config.SaveConfig or false
    self.Folder = config.ConfigFolder or "NovaUI"

    local gui = Create("ScreenGui", {
        Name = "NovaUI",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
    })
    if gethui then gui.Parent = gethui() else gui.Parent = CoreGui end
    self.GUI = gui

    -- Main frame
    local main = Create("Frame", {
        Parent = gui,
        Size = UDim2.new(0, 680, 0, 480),
        Position = UDim2.new(0.5, -340, 0.5, -240),
        BackgroundColor3 = NovaUI.Theme.Background,
        BorderSizePixel = 0,
        Name = "Main",
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 10) }),
        Create("UIStroke", { Color = NovaUI.Theme.ElementBorder, Thickness = 1 }),
        -- Shadow
        Create("ImageLabel", {
            Image = "rbxassetid://5028857084",
            Size = UDim2.new(1, 40, 1, 40),
            Position = UDim2.new(-0.5, -20, -0.5, -20),
            BackgroundTransparency = 1,
            ImageTransparency = 0.85,
            ImageColor3 = NovaUI.Theme.Shadow,
        }),
    })

    -- Top bar
    local topbar = Create("Frame", {
        Parent = main,
        Size = UDim2.new(1, 0, 0, 36),
        BackgroundColor3 = NovaUI.Theme.Sidebar,
        Name = "TopBar",
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 10) }),
        Create("ImageLabel", { Size = UDim2.new(0, 20, 0, 20), Position = UDim2.new(0, 12, 0, 8), Image = config.Icon or "rbxassetid://4483345875", BackgroundTransparency = 1 }),
        Create("TextLabel", {
            Size = UDim2.new(0, 200, 0, 20),
            Position = UDim2.new(0, 38, 0, 8),
            Text = config.Title or "Nova UI",
            Font = Enum.Font.GothamBold,
            TextColor3 = NovaUI.Theme.Text,
            BackgroundTransparency = 1,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextSize = 15,
        }),
        Create("TextButton", {
            Size = UDim2.new(0, 28, 0, 28),
            Position = UDim2.new(1, -34, 0, 4),
            BackgroundColor3 = Color3.fromRGB(230, 60, 60),
            Text = "✕",
            Font = Enum.Font.GothamBold,
            TextColor3 = Color3.new(1,1,1),
            BorderSizePixel = 0,
        }, { Create("UICorner", { CornerRadius = UDim.new(0, 5) }) }),
    })
    local closeBtn = topbar.TextButton
    closeBtn.MouseButton1Click:Connect(function()
        main.Visible = false
        NovaUI:Notify({Title = "Hidden", Content = "Press RightShift to open again", Duration = 3})
        self.AddConnection(UserInputService.InputBegan, function(input)
            if input.KeyCode == Enum.KeyCode.RightShift then main.Visible = true end
        end)
    end)
    MakeDraggable(main, topbar)

    -- Sidebar for tabs
    local sidebar = Create("ScrollingFrame", {
        Parent = main,
        Size = UDim2.new(0, 170, 1, -36),
        Position = UDim2.new(0, 0, 0, 36),
        BackgroundColor3 = NovaUI.Theme.Sidebar,
        BorderSizePixel = 0,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = NovaUI.Theme.ElementBorder,
        CanvasSize = UDim2.new(0, 0, 0, 0),
    }, {
        Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 6) }),
        Create("UIPadding", { PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10), PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10) }),
    })
    UpdateScroll(sidebar)

    -- Content area
    local content = Create("ScrollingFrame", {
        Parent = main,
        Size = UDim2.new(1, -170, 1, -36),
        Position = UDim2.new(0, 170, 0, 36),
        BackgroundTransparency = 1,
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = NovaUI.Theme.ElementBorder,
        CanvasSize = UDim2.new(0, 0, 0, 0),
    }, {
        Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 10) }),
        Create("UIPadding", { PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12), PaddingTop = UDim.new(0, 12), PaddingBottom = UDim.new(0, 12) }),
    })
    UpdateScroll(content)

    local currentTab = nil
    local tabsList = {}

    function window:CreateTab(tabData)
        local tabBtn = Create("TextButton", {
            Parent = sidebar,
            Size = UDim2.new(1, 0, 0, 34),
            Text = "",
            BackgroundColor3 = NovaUI.Theme.Tab,
            AutoButtonColor = false,
        }, {
            Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
            Create("ImageLabel", { Size = UDim2.new(0, 18, 0, 18), Position = UDim2.new(0, 10, 0.5, -9), Image = tabData.Icon or "rbxassetid://4483345875", BackgroundTransparency = 1 }),
            Create("TextLabel", {
                Size = UDim2.new(1, -34, 1, 0),
                Position = UDim2.new(0, 34, 0, 0),
                Text = tabData.Name,
                Font = Enum.Font.Gotham,
                TextColor3 = NovaUI.Theme.SubText,
                BackgroundTransparency = 1,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextSize = 14,
            })
        })

        local tabPage = Create("Frame", {
            Parent = content,
            Size = UDim2.new(1, 0, 0, 0),
            BackgroundTransparency = 1,
            Visible = false,
            AutomaticSize = Enum.AutomaticSize.Y,
        }, {
            Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 8) }),
        })

        -- First tab activation
        if not currentTab then
            currentTab = { btn = tabBtn, page = tabPage }
            tabBtn.BackgroundColor3 = NovaUI.Theme.TabSelected
            tabBtn.TextLabel.TextColor3 = Color3.new(1,1,1)
            tabPage.Visible = true
        end

        tabBtn.MouseEnter:Connect(function()
            if currentTab and currentTab.btn ~= tabBtn then
                Tween(tabBtn, {BackgroundColor3 = NovaUI.Theme.TabHover}, 0.2)
            end
        end)
        tabBtn.MouseLeave:Connect(function()
            if currentTab and currentTab.btn ~= tabBtn then
                Tween(tabBtn, {BackgroundColor3 = NovaUI.Theme.Tab}, 0.2)
            end
        end)
        tabBtn.MouseButton1Click:Connect(function()
            if currentTab then
                Tween(currentTab.btn, {BackgroundColor3 = NovaUI.Theme.Tab}, 0.2)
                currentTab.btn.TextLabel.TextColor3 = NovaUI.Theme.SubText
                currentTab.page.Visible = false
            end
            currentTab = { btn = tabBtn, page = tabPage }
            Tween(tabBtn, {BackgroundColor3 = NovaUI.Theme.TabSelected}, 0.2)
            tabBtn.TextLabel.TextColor3 = Color3.new(1,1,1)
            tabPage.Visible = true
        end)

        local tab = { Container = tabPage }
        function tab:CreateSection(name)
            local section = Create("Frame", {
                Parent = tabPage,
                Size = UDim2.new(1, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,
            }, {
                Create("TextLabel", {
                    Size = UDim2.new(1, 0, 0, 20),
                    Text = name,
                    Font = Enum.Font.GothamBold,
                    TextColor3 = NovaUI.Theme.SubText,
                    BackgroundTransparency = 1,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextSize = 12,
                }),
                Create("Frame", {
                    Size = UDim2.new(1, 0, 1, -20),
                    Position = UDim2.new(0, 0, 0, 22),
                    BackgroundTransparency = 1,
                    Name = "Elements",
                }, {
                    Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 6) }),
                })
            })
            return setmetatable({ Container = section.Elements }, { __index = Elements })
        end
        return setmetatable(tab, { __index = Elements })
    end

    return window
end

function NovaUI:Destroy()
    if self.GUI then
        self.GUI:Destroy()
        Cleanup()
    end
end

return NovaUI
