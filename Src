-- Helper functions
local function SafeDelay(t, f) delay(t, f) end

local function Create(class, props, children)
    local obj = Instance.new(class)
    for k, v in pairs(props or {}) do obj[k] = v end
    for _, child in ipairs(children or {}) do child.Parent = obj end
    return obj
end

local function Tween(obj, goal, t, style, dir)
    local tween = TweenService:Create(obj, TweenInfo.new(t or 0.3, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out), goal)
    tween:Play()
    return tween
end

function Library.AddConnection(sig, cb)
    local conn = sig:Connect(cb)
    table.insert(Library.Connections, conn)
    return conn
end

local function Cleanup()
    for _, c in ipairs(Library.Connections) do c:Disconnect() end
    Library.Connections = {}
end

-- Mobile‑safe dragging
local function MakeDraggable(frame, topbar)
    local dragging, dragStart, startPos
    local function onBegan(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end
    local function onChanged(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end
    local function onEnded(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end
    topbar.InputBegan:Connect(onBegan)
    topbar.InputChanged:Connect(onChanged)
    topbar.InputEnded:Connect(onEnded)
end

