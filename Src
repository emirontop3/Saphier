            TextSize = 14,
        }),
        Create("Frame", {
            Size = UDim2.new(0, 24, 0, 24),
            Position = UDim2.new(1, -34, 0.5, -12),
            BackgroundColor3 = color,
            Name = "Display",
        }, { Create("UICorner", { CornerRadius = UDim.new(0, 4) }) }),
        Create("TextLabel", { Name = "R", Size = UDim2.new(0, 50, 0, 12), Position = UDim2.new(0, 12, 1, -28), Text = "R: 255", Font = Enum.Font.Gotham, TextColor3 = Library.Theme.TextDark, BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left }),
        Create("TextLabel", { Name = "G", Size = UDim2.new(0, 50, 0, 12), Position = UDim2.new(0, 72, 1, -28), Text = "G: 255", Font = Enum.Font.Gotham, TextColor3 = Library.Theme.TextDark, BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left }),
        Create("TextLabel", { Name = "B", Size = UDim2.new(0, 50, 0, 12), Position = UDim2.new(0, 132, 1, -28), Text = "B: 255", Font = Enum.Font.Gotham, TextColor3 = Library.Theme.TextDark, BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left }),
        Create("TextBox", { Name = "RInput", Size = UDim2.new(0, 40, 0, 16), Position = UDim2.new(0, 200, 1, -26), Text = "255", Font = Enum.Font.Gotham, TextColor3 = Library.Theme.Text, BackgroundColor3 = Library.Theme.Input, ClearTextOnFocus = false }),
        Create("TextBox", { Name = "GInput", Size = UDim2.new(0, 40, 0, 16), Position = UDim2.new(0, 260, 1, -26), Text = "255", Font = Enum.Font.Gotham, TextColor3 = Library.Theme.Text, BackgroundColor3 = Library.Theme.Input, ClearTextOnFocus = false }),
        Create("TextBox", { Name = "BInput", Size = UDim2.new(0, 40, 0, 16), Position = UDim2.new(0, 320, 1, -26), Text = "255", Font = Enum.Font.Gotham, TextColor3 = Library.Theme.Text, BackgroundColor3 = Library.Theme.Input, ClearTextOnFocus = false }),
    })
    picker._frame = frame

    local function updateFromTextBoxes()
        local r = math.clamp(tonumber(frame.RInput.Text) or 0, 0, 255)
        local g = math.clamp(tonumber(frame.GInput.Text) or 0, 0, 255)
        local b = math.clamp(tonumber(frame.BInput.Text) or 0, 0, 255)
        picker.Set(Color3.fromRGB(r, g, b))
    end
    frame.RInput.FocusLost:Connect(updateFromTextBoxes)
    frame.GInput.FocusLost:Connect(updateFromTextBoxes)
    frame.BInput.FocusLost:Connect(updateFromTextBoxes)

    picker.Set(color)
    if data.Flag then Library.Flags[data.Flag] = picker end
    UpdateScrollSize(self.Container.Parent)
    return picker
end

-- Window creation
function Library:CreateWindow(data)
    local window = {}
    self.SaveCfg = data.SaveConfig or false
    self.Folder = data.ConfigFolder or "SimpleUI"

    local gui = Create("ScreenGui", {
        Name = "SimpleUI",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
    })
    if gethui then gui.Parent = gethui() else gui.Parent = CoreGui end
    self.GUI = gui

    local main = Create("Frame", {
        Parent = gui,
        Size = UDim2.new(0, 650, 0, 460),
        Position = UDim2.new(0.5, -325, 0.5, -230),
        BackgroundColor3 = Library.Theme.Background,
        BorderSizePixel = 0,
        Name = "Main",
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 10) }),
        Create("UIStroke", { Color = Library.Theme.Stroke, Thickness = 1 }),
        Create("Frame", { -- shadow effect
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            ZIndex = -1,
        }, { Create("ImageLabel", {
            Image = "rbxassetid://5028857084", -- simple shadow
            Size = UDim2.new(1, 30, 1, 30),
            Position = UDim2.new(-0.5, -15, -0.5, -15),
            BackgroundTransparency = 1,
            ImageTransparency = 0.8,
            ImageColor3 = Library.Theme.Shadow,
        })}),
    })

    local topbar = Create("Frame", {
        Parent = main,
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundColor3 = Library.Theme.TopBar,
        Name = "TopBar",
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 10) }),
        Create("ImageLabel", { Size = UDim2.new(0, 22, 0, 22), Position = UDim2.new(0, 12, 0, 9), Image = data.Icon or "rbxassetid://4483345875", BackgroundTransparency = 1 }),
        Create("TextLabel", {
            Size = UDim2.new(0, 200, 0, 22),
            Position = UDim2.new(0, 40, 0, 9),
            Text = data.Title or "SimpleUI",
            Font = Enum.Font.GothamBold,
            TextColor3 = Library.Theme.Text,
            BackgroundTransparency = 1,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextSize = 16,
            TextTruncate = Enum.TextTruncate.AtEnd,
        }),
        Create("TextButton", {
            Size = UDim2.new(0, 30, 0, 30),
            Position = UDim2.new(1, -35, 0, 5),
            BackgroundColor3 = Color3.fromRGB(220, 60, 60),
            Text = "✕",
            Font = Enum.Font.GothamBold,
            TextColor3 = Color3.new(1,1,1),
            BorderSizePixel = 0,
        }, {
            Create("UICorner", { CornerRadius = UDim.new(0, 5) }),
        })
    })

    local closeBtn = topbar.TextButton
    closeBtn.MouseButton1Click:Connect(function()
        main.Visible = false
        self:Notify({Title = "Hidden", Content = "Press RightShift to reopen", Duration = 3})
        self.AddConnection(UserInputService.InputBegan, function(input)
            if input.KeyCode == Enum.KeyCode.RightShift then main.Visible = true end
        end)
    end)

    MakeDraggable(main, topbar)

    -- Tab container (scrollable)
    local tabScroll = Create("ScrollingFrame", {
        Parent = main,
        Size = UDim2.new(0, 160, 1, -40),
        Position = UDim2.new(0, 0, 0, 40),
        BackgroundColor3 = Library.Theme.Background:Lerp(Color3.new(0,0,0), 0.2),
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Library.Theme.Stroke,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        BorderSizePixel = 0,
    }, {
        Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 6) }),
        Create("UIPadding", { PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 8), PaddingTop = UDim.new(0, 10) }),
    })

    -- Content area (scrollable)
    local content = Create("ScrollingFrame", {
        Parent = main,
        Size = UDim2.new(1, -170, 1, -40),
        Position = UDim2.new(0, 160, 0, 40),
        BackgroundTransparency = 1,
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = Library.Theme.Stroke,
        CanvasSize = UDim2.new(0, 0, 0, 0),
    }, {
        Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 10) }),
        Create("UIPadding", { PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10), PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10) }),
    })

    -- Update tab scroll canvas
    local function updateTabScroll()
        local layout = tabScroll:FindFirstChildWhichIsA("UIListLayout")
        if layout then
            tabScroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
        end
    end

    local currentTab

    function window:CreateTab(tabData)
        local tabBtn = Create("TextButton", {
            Parent = tabScroll,
            Size = UDim2.new(1, 0, 0, 32),
            Text = "",
            BackgroundColor3 = Library.Theme.Tab,
            AutoButtonColor = false,
        }, {
            Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
            Create("ImageLabel", { Size = UDim2.new(0, 18, 0, 18), Position = UDim2.new(0, 8, 0.5, -9), Image = tabData.Icon or "rbxassetid://4483345875", BackgroundTransparency = 1 }),
            Create("TextLabel", {
                Size = UDim2.new(1, -30, 1, 0),
                Position = UDim2.new(0, 30, 0, 0),
                Text = tabData.Name,
                Font = Enum.Font.Gotham,
                TextColor3 = Library.Theme.TextDark,
                BackgroundTransparency = 1,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextSize = 14,
            })
        })

        local tabPage = Create("Frame", {
            Parent = content,
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Visible = false,
        }, {
            Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 8) }),
        })

        if not currentTab then
            currentTab = { btn = tabBtn, page = tabPage }
            tabBtn.BackgroundColor3 = Library.Theme.TabSelected
            tabBtn.TextLabel.TextColor3 = Library.Theme.Text
            tabPage.Visible = true
        end

        tabBtn.MouseButton1Click:Connect(function()
            if currentTab then
                currentTab.btn.BackgroundColor3 = Library.Theme.Tab
                currentTab.btn.TextLabel.TextColor3 = Library.Theme.TextDark
                currentTab.page.Visible = false
            end
            currentTab = { btn = tabBtn, page = tabPage }
            tabBtn.BackgroundColor3 = Library.Theme.TabSelected
            tabBtn.TextLabel.TextColor3 = Library.Theme.Text
            tabPage.Visible = true
        end)

        updateTabScroll()

        local tab = { Container = tabPage }

        function tab:CreateSection(name)
            local section = Create("Frame", {
                Parent = tabPage,
                Size = UDim2.new(1, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,
            }, {
                Create("TextLabel", {
                    Size = UDim2.new(1, 0, 0, 20),
                    Text = name,
                    Font = Enum.Font.GothamBold,
                    TextColor3 = Library.Theme.TextDark,
                    BackgroundTransparency = 1,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextSize = 13,
                }),
                Create("Frame", {
                    Size = UDim2.new(1, 0, 1, -20),
                    Position = UDim2.new(0, 0, 0, 22),
                    BackgroundTransparency = 1,
                    Name = "Holder",
                }, {
                    Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 6) }),
                })
            })
            return setmetatable({Container = section.Holder}, {__index = ElementFunctions})
        end

        return setmetatable(tab, {__index = ElementFunctions})
    end

    -- Update content scroll when children change
    content.ChildAdded:Connect(function()
        UpdateScrollSize(content)
    end)
    content.ChildRemoved:Connect(function()
        UpdateScrollSize(content)
    end)

    return window
end

function Library:Destroy()
    if self.GUI then
        self.GUI:Destroy()
        Cleanup()
    end
end

return Library
