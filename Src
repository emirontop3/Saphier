local function packColor(c) return {R = c.R*255, G = c.G*255, B = c.B*255} end
local function unpackColor(t) return Color3.fromRGB(t.R, t.G, t.B) end
local function round(n, inc) return math.floor(n/inc + math.sign(n)*0.5)*inc end

local function safeCallback(fn, ...)
    if fn then
        local ok, err = pcall(fn, ...)
        if not ok then warn("Aurora – Callback error: "..tostring(err)) end
    end
end

local function checkConfig(c, type)
    if type ~= "table" then
        warn("Aurora – "..type.." expects a table config, got "..typeof(c))
        return false
    end
    if not c.Name then c.Name = "Unnamed" end
    return true
end

-- Connection manager
local connections = {}
local function addConnection(sig, fn)
    local con = sig:Connect(fn)
    table.insert(connections, con)
