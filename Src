-- Configuration
local function PackColor(color)
    return {R = math.floor(color.R * 255), G = math.floor(color.G * 255), B = math.floor(color.B * 255)}
end
local function UnpackColor(t)
    return Color3.fromRGB(t.R, t.G, t.B)
end

function Library:LoadConfig(name)
    if not self.SaveCfg then return end
    local path = self.Folder .. "/" .. name .. ".json"
    if isfile and isfile(path) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
        if success then
            for flag, value in pairs(data) do
                if self.Flags[flag] then
                    if self.Flags[flag].Type == "ColorPicker" then
                        self.Flags[flag]:Set(UnpackColor(value))
                    else
                        self.Flags[flag]:Set(value)
                    end
                end
            end
            self:Notify({Title = "Config", Content = "Loaded configuration from " .. name, Duration = 3})
        end
    end
end

function Library:SaveConfig(name)
    if not self.SaveCfg then return end
    local path = self.Folder .. "/" .. name .. ".json"
    local data = {}
    for flag, obj in pairs(self.Flags) do
        if obj.Save then
            if obj.Type == "ColorPicker" then
                data[flag] = PackColor(obj.Value)
            else
                data[flag] = obj.Value
            end
        end
    end
    if writefile then
        makefolder(self.Folder)
        writefile(path, HttpService:JSONEncode(data))
        self:Notify({Title = "Config", Content = "Saved configuration as " .. name, Duration = 3})
    end
end

