function ElementFunctions:AddSlider(data)
    local val = data.Default or data.Min or 0
    local slider = {}
    slider.Save = data.Save or false
    slider.Type = "Slider"
    slider.Set = function(v)
        v = math.clamp(tonumber(v) or 0, data.Min, data.Max)
        local factor = (v - data.Min) / (data.Max - data.Min)
        bar.Progress.Size = UDim2.new(factor, 0, 1, 0)
        bar.Value.Text = tostring(v) .. (data.Suffix or "")
        if data.Callback then pcall(data.Callback, v) end
    end
    slider.Get = function() return val end

    local frame = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 50),
        BackgroundColor3 = Library.Theme.Element,
        Parent = self.Container,
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
        Create("UIStroke", { Color = Library.Theme.Stroke }),
        Create("TextLabel", {
            Size = UDim2.new(1, -12, 0, 20),
            Position = UDim2.new(0, 12, 0, 4),
            Text = data.Name,
            Font = Enum.Font.GothamBold,
            TextColor3 = Library.Theme.Text,
            BackgroundTransparency = 1,
            TextXAlignment = Enum.TextXAlignment.Left,
        }),
        Create("Frame", {
            Size = UDim2.new(1, -24, 0, 20),
            Position = UDim2.new(0, 12, 0, 25),
            BackgroundColor3 = Library.Theme.Element:Lerp(Color3.new(1,1,1), 0.3),
            Name = "SliderBar",
        }, {
            Create("UICorner", { CornerRadius = UDim.new(0, 4) }),
            Create("Frame", {
                Size = UDim2.new(0, 0, 1, 0),
                BackgroundColor3 = Library.Theme.Slider,
                Name = "Progress",
            }, { Create("UICorner", { CornerRadius = UDim.new(0, 4) }) }),
            Create("TextLabel", {
                Size = UDim2.new(0, 50, 1, 0),
                Position = UDim2.new(1, 6, 0, 0),
                Text = tostring(val),
                Font = Enum.Font.GothamBold,
                TextColor3 = Library.Theme.TextDark,
                BackgroundTransparency = 1,
                TextXAlignment = Enum.TextXAlignment.Left,
                Name = "Value",
            })
        })
    })
    local bar = frame.SliderBar

    local dragging
    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)
    bar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local perc = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
            val = data.Min + (data.Max - data.Min) * perc
            slider.Set(val)
        end
    end)

    slider.Set(val)
    if data.Flag then Library.Flags[data.Flag] = slider end
    return slider
end

function ElementFunctions:AddDropdown(data)
    local options = data.Options or {}
    local selected = data.Default and table.find(options, data.Default) and data.Default or "Select..."
    local drop = {}
    drop.Save = data.Save or false
    drop.Type = "Dropdown"
    drop.Set = function(val)
        if table.find(options, val) then
            selected = val
            header.Selected.Text = val
            for _, btn in ipairs(list:GetChildren()) do
                if btn:IsA("TextButton") then
                    Tween(btn, {BackgroundTransparency = btn.Text == val and 0.7 or 1}, 0.2)
                end
            end
            if data.Callback then pcall(data.Callback, val) end
        end
    end
    drop.Get = function() return selected end

    local frame = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 36),
        BackgroundColor3 = Library.Theme.Element,
        Parent = self.Container,
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
        Create("UIStroke", { Color = Library.Theme.Stroke }),
        Create("Frame", {
            Size = UDim2.new(1, 0, 0, 36),
            BackgroundTransparency = 1,
            Name = "Header",
        }, {
            Create("TextLabel", {
                Size = UDim2.new(1, -40, 1, 0),
                Position = UDim2.new(0, 12, 0, 0),
                Text = selected,
                Font = Enum.Font.GothamBold,
                TextColor3 = Library.Theme.Text,
                BackgroundTransparency = 1,
                TextXAlignment = Enum.TextXAlignment.Left,
                Name = "Selected",
            }),
            Create("ImageButton", {
                Size = UDim2.new(0, 20, 0, 20),
                Position = UDim2.new(1, -30, 0.5, -10),
                Image = "rbxassetid://7072706796", -- down arrow
                BackgroundTransparency = 1,
                Name = "Arrow",
            })
        })
    })
    local header = frame.Header
    local list = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = Library.Theme.Dropdown,
        ClipsDescendants = true,
        Visible = false,
        Parent = frame,
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
        Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 2) }),
        Create("UIPadding", { PaddingTop = UDim.new(0, 2), PaddingBottom = UDim.new(0, 2) })
    })

    local toggled = false
    header.Arrow.MouseButton1Click:Connect(function()
        toggled = not toggled
        if toggled then
            list.Size = UDim2.new(1, 0, 0, #options * 26 + 4)
            list.Visible = true
            Tween(header.Arrow, {Rotation = 180}, 0.2)
        else
            list.Visible = false
            Tween(header.Arrow, {Rotation = 0}, 0.2)
            Tween(frame, {Size = UDim2.new(1, 0, 0, 36)}, 0.2)
        end
    end)

    for _, opt in ipairs(options) do
        local optBtn = Create("TextButton", {
            Text = opt,
            Font = Enum.Font.Gotham,
            TextColor3 = Library.Theme.Text,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -8, 0, 24),
            Position = UDim2.new(0, 4, 0, 0),
            Parent = list,
        }, {
            Create("UICorner", { CornerRadius = UDim.new(0, 4) }),
        })
        optBtn.MouseButton1Click:Connect(function()
            drop.Set(opt)
            toggled = false
            list.Visible = false
            Tween(header.Arrow, {Rotation = 0}, 0.2)
            Tween(frame, {Size = UDim2.new(1, 0, 0, 36)}, 0.2)
        end)
        if opt == selected then
            optBtn.BackgroundTransparency = 0.7
        end
    end

    drop.Set(selected)
    if data.Flag then Library.Flags[data.Flag] = drop end
    return drop
end

function ElementFunctions:AddKeybind(data)
    local bind = data.Default or Enum.KeyCode.Unknown
    local binding = false
    local keybind = {}
    keybind.Save = data.Save or false
    keybind.Type = "Keybind"
    keybind.Set = function(key)
        if typeof(key) == "EnumItem" then key = key end
        if typeof(key) == "string" then key = Enum.KeyCode[key] or bind end
        bind = key
        frame.Value.Text = key.Name
    end
    keybind.Get = function() return bind end

    local frame = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundColor3 = Library.Theme.Element,
        Parent = self.Container,
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
        Create("UIStroke", { Color = Library.Theme.Stroke }),
        Create("TextLabel", {
            Size = UDim2.new(1, -80, 1, 0),
            Position = UDim2.new(0, 12, 0, 0),
            Text = data.Name,
            Font = Enum.Font.GothamBold,
            TextColor3 = Library.Theme.Text,
            BackgroundTransparency = 1,
            TextXAlignment = Enum.TextXAlignment.Left,
        }),
        Create("TextButton", {
            Size = UDim2.new(0, 60, 0, 24),
            Position = UDim2.new(1, -70, 0.5, -12),
            Text = bind.Name,
            Font = Enum.Font.GothamBold,
            TextColor3 = Library.Theme.Text,
            BackgroundColor3 = Library.Theme.Input,
            Name = "Value",
        }, {
            Create("UICorner", { CornerRadius = UDim.new(0, 4) }),
            Create("UIStroke", { Color = Library.Theme.Stroke }),
        })
    })

    local valBtn = frame.Value
    valBtn.MouseButton1Click:Connect(function()
        binding = true
        valBtn.Text = "..."
    end)

    UserInputService.InputBegan:Connect(function(input)
        if binding then
            if input.KeyCode ~= Enum.KeyCode.Unknown then
                keybind.Set(input.KeyCode)
                binding = false
            end
        elseif not binding and input.KeyCode == bind and not UserInputService:GetFocusedTextBox() then
            if data.Callback then pcall(data.Callback) end
        end
    end)

    if data.Flag then Library.Flags[data.Flag] = keybind end
    return keybind
end

