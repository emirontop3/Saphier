-- Config helpers
local function PackColor(c) return {R = math.floor(c.R*255), G = math.floor(c.G*255), B = math.floor(c.B*255)} end
local function UnpackColor(t) return Color3.fromRGB(t.R, t.G, t.B) end

function Library:LoadConfig(name)
    if not self.SaveCfg then return end
    local path = self.Folder .. "/" .. name .. ".json"
    if isfile and isfile(path) then
        local ok, dat = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
        if ok then
            for flag, val in pairs(dat) do
                if self.Flags[flag] then
                    if self.Flags[flag].Type == "ColorPicker" then
                        self.Flags[flag]:Set(UnpackColor(val))
                    else
                        self.Flags[flag]:Set(val)
                    end
                end
            end
            self:Notify({Title = "Config", Content = "Loaded " .. name, Duration = 3})
        end
    end
end

function Library:SaveConfig(name)
    if not self.SaveCfg then return end
    local path = self.Folder .. "/" .. name .. ".json"
    local dat = {}
    for flag, obj in pairs(self.Flags) do
        if obj.Save then
            if obj.Type == "ColorPicker" then
                dat[flag] = PackColor(obj.Value)
            else
                dat[flag] = obj.Value
            end
        end
    end
    if writefile then
        makefolder(self.Folder)
        writefile(path, HttpService:JSONEncode(dat))
        self:Notify({Title = "Config", Content = "Saved " .. name, Duration = 3})
    end
end

-- Element creation helpers
local function UpdateScrollSize(container)
    if container:IsA("ScrollingFrame") then
        local layout = container:FindFirstChildWhichIsA("UIListLayout")
        if layout then
            container.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
        end
    end
end

