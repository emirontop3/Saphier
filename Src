				TextXAlignment = Enum.TextXAlignment.Right,
				Parent = slider
			})
			AddThemeObject(valueLabel, "TextDark")

			local bar = Create("Frame", {
				Size = UDim2.new(1, -24, 0, 6),
				Position = UDim2.new(0, 12, 0, 32),
				BackgroundColor3 = AuroraLib.Theme[theme].SliderBG,
				Parent = slider
			}, {
				Create("UICorner", {CornerRadius = UDim.new(0, 3)})
			})
			AddThemeObject(bar, "SliderBG")
			local fill = Create("Frame", {
				Size = UDim2.fromScale((default - min) / (max - min), 1),
				BackgroundColor3 = AuroraLib.Theme[theme].SliderFill,
				Parent = bar
			}, {
				Create("UICorner", {CornerRadius = UDim.new(0, 3)})
			})
			AddThemeObject(fill, "SliderFill")
			local knob = Create("Frame", {
				Size = UDim2.new(0, 10, 0, 16),
				Position = UDim2.new((default - min) / (max - min), -5, 0.5, -8),
				BackgroundColor3 = Color3.new(1, 1, 1),
				Parent = bar
			}, {
				Create("UICorner", {CornerRadius = UDim.new(0, 3)})
			})

			local dragging = false
			local function updateValue(val)
				val = math.clamp(Round(val, increment), min, max)
				local frac = (val - min) / (max - min)
				TweenService:Create(fill, TweenInfo.new(0.1), {Size = UDim2.fromScale(frac, 1)}):Play()
				TweenService:Create(knob, TweenInfo.new(0.1), {Position = UDim2.new(frac, -5, 0.5, -8)}):Play()
				valueLabel.Text = tostring(val) .. suffix
				callback(val)
				if save and flag then
					AuroraLib.Flags[flag] = {Value = val, Save = save}
					SaveCfg(flag, val)
				end
			end
			bar.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = true
				end
			end)
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = false
				end
			end)
			UserInputService.InputChanged:Connect(function(input)
				if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
					local mouseX = input.Position.X
					local barSize = bar.AbsoluteSize.X
					local barPos = bar.AbsolutePosition.X
					local frac = math.clamp((mouseX - barPos) / barSize, 0, 1)
					local newVal = min + frac * (max - min)
					updateValue(newVal)
				end
			end)
			return {Set = function(val) updateValue(val) end}
		end

