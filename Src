local function AddWindowControls(window, topbar, mainFrame)
    local closeBtn = Create("ImageButton", {
        Size = UDim2.new(0, 24, 0, 24),
        Position = UDim2.new(1, -28, 0, 6),
        BackgroundTransparency = 1,
        Image = "rbxassetid://7733658504", -- X icon (use a known asset)
        Parent = topbar
    })
    local minBtn = Create("ImageButton", {
        Size = UDim2.new(0, 24, 0, 24),
        Position = UDim2.new(1, -56, 0, 6),
        BackgroundTransparency = 1,
        Image = "rbxassetid://7733662779", -- minimize icon
        Parent = topbar
    })
    local maxBtn = Create("ImageButton", {
        Size = UDim2.new(0, 24, 0, 24),
        Position = UDim2.new(1, -84, 0, 6),
        BackgroundTransparency = 1,
        Image = "rbxassetid://7733670478", -- maximize icon
        Parent = topbar
    })

    local minimized = false
    local maximized = false
    local origSize = mainFrame.Size
    local origPos = mainFrame.Position

    minBtn.MouseButton1Click:Connect(function()
        if minimized then
            mainFrame.Size = origSize
            mainFrame.Position = origPos
            for _, child in ipairs(mainFrame:GetChildren()) do
                if child.Name ~= "TopBar" then child.Visible = true end
            end
        else
            origSize = mainFrame.Size
            origPos = mainFrame.Position
            mainFrame.Size = UDim2.new(0, origSize.X.Offset, 0, 35)
            for _, child in ipairs(mainFrame:GetChildren()) do
                if child.Name ~= "TopBar" then child.Visible = false end
            end
        end
        minimized = not minimized
    end)

    maxBtn.MouseButton1Click:Connect(function()
        if maximized then
            mainFrame.Size = origSize
            mainFrame.Position = origPos
        else
            origSize = mainFrame.Size
            origPos = mainFrame.Position
            mainFrame.Size = UDim2.new(0, workspace.CurrentCamera.ViewportSize.X - 40, 0, workspace.CurrentCamera.ViewportSize.Y - 40)
            mainFrame.Position = UDim2.new(0, 20, 0, 20)
        end
        maximized = not maximized
    end)

    closeBtn.MouseButton1Click:Connect(function()
        mainFrame.Visible = false
        Library.AddConnection(UserInputService.InputBegan, function(input)
            if input.KeyCode == Enum.KeyCode.RightShift then mainFrame.Visible = true end
        end)
    end)
end

